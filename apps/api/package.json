{
  "name": "@venta/api",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "imports": {
    "#domain/*": "./src/domain/*.ts",
    "#application/*": "./src/application/*.ts",
    "#infrastructure/*": "./src/infrastructure/*.ts",
    "#interfaces/*": "./src/interfaces/*.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@venta/types": "*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
